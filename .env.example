# Insitu-Photos Configuration

# Host Paths (Change these to match your server setup)
HOST_APPDATA_PATH=/mnt/user/appdata/insitu-photos
HOST_PHOTO_PATH=/mnt/user/photos

# Database
POSTGRES_USER=photos
POSTGRES_PASSWORD=photos_pass
POSTGRES_DB=insitu_photos

# Authentication
SECRET_KEY=change_this_to_a_secure_random_string
ADMIN_USER=admin
ADMIN_PASSWORD=admin_password

# Telemetry (Optional)
OTEL_EXPORTER_OTLP_ENDPOINT=none
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=none
